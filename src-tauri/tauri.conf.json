{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Jarvas",
  "version": "0.1.2",
  "identifier": "br.vet.agendavet.jood",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/melowesley/jarvas-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlCODM1NUVGQTYyOEIyQzYKUldUR3NpaW03MVdEbTd1S3lnTHVGckxaMFdqRnIxQlJBSVc0d2ovbkV2WHhVcUhmWkNxUkRqbmcK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
